{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "dashboard/Routes": [
        "apps/dashboard/src/app/remote-entry/entry.routes.ts"
      ],
      "profile/Routes": ["apps/profile/src/app/remote-entry/entry.routes.ts"],
      "lab/Routes": ["apps/lab/src/app/remote-entry/entry.routes.ts"],
      "theme/Routes": ["apps/theme/src/app/remote-entry/entry.routes.ts"],
      "demos/Routes": ["apps/demos/src/app/remote-entry/entry.routes.ts"],
      "@ng-mfe-hub/ui": ["libs/shared/ui/src/index.ts"],
      "@ng-mfe-hub/data-access": ["libs/shared/data-access/src/index.ts"],
      "@ng-mfe-hub/util": ["libs/shared/util/src/index.ts"],
      "@ng-mfe-hub/styles": ["libs/shared/styles/src/index.ts"],
      "@ng-mfe-hub/dashboard-ui": ["libs/dashboard/ui/src/index.ts"],
      "@ng-mfe-hub/dashboard-data-access": [
        "libs/dashboard/data-access/src/index.ts"
      ],
      "@ng-mfe-hub/dashboard-feature-users": [
        "libs/dashboard/feature-users/src/index.ts"
      ],
      "jobs/Routes": ["apps/jobs/src/app/remote-entry/entry.routes.ts"],
      "eco-tracker/Routes": [
        "apps/eco-tracker/src/app/remote-entry/entry.routes.ts"
      ],
      "@ng-mfe-hub/jobs-data-access": ["libs/jobs/data-access/src/index.ts"],
      "@ng-mfe-hub/jobs-ui": ["libs/jobs/ui/src/index.ts"],
      "@ng-mfe-hub/jobs-feature-search": [
        "libs/jobs/feature-search/src/index.ts"
      ],
      "@ng-mfe-hub/lab-data-access": ["libs/lab/data-access/src/index.ts"],
      "@ng-mfe-hub/lab-ui": ["libs/lab/ui/src/index.ts"],
      "@ng-mfe-hub/lab-feature-docs": ["libs/lab/feature-docs/src/index.ts"],
      "@ng-mfe-hub/eco-tracker-data-access": [
        "libs/eco-tracker/data-access/src/index.ts"
      ],
      "@ng-mfe-hub/eco-tracker-ui": ["libs/eco-tracker/ui/src/index.ts"],
      "@ng-mfe-hub/eco-tracker-feature-dashboard": [
        "libs/eco-tracker/feature-dashboard/src/index.ts"
      ],
      "@ng-mfe-hub/eco-tracker-feature-trees": [
        "libs/eco-tracker/feature-trees/src/index.ts"
      ],
      "@ng-mfe-hub/eco-tracker-feature-footprint": [
        "libs/eco-tracker/feature-footprint/src/index.ts"
      ],
      "@ng-mfe-hub/eco-tracker-feature-insights": [
        "libs/eco-tracker/feature-insights/src/index.ts"
      ],
      "@ng-mfe-hub/eco-tracker-feature-community": [
        "libs/eco-tracker/feature-community/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
